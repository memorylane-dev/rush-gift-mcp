# ── rush-gift-mcp 환경 변수 ──────────────────────────────────────────
# 사용법 (로컬):
#   1. 이 파일을 복사:  cp .env.example .env
#   2. .env 에 실제 값 입력 (.env 는 gitignore 되어 있어 커밋되지 않음)
# 배포 (Vercel):
#   .env 파일은 배포에 포함되지 않는다.
#   Vercel 대시보드 > 프로젝트 > Settings > Environment Variables 에 직접 입력.

# 장소 좌표 provider 선택: fixture | kakao_local | tmap
RUSH_GIFT_PLACE_PROVIDER=fixture

# 이동 시간 provider 선택: mock | kakao_mobility | tmap
RUSH_GIFT_ROUTE_PROVIDER=mock

# TMAP (openapi.sk.com) 앱 키. 개인 개발자 무료 발급 가능.
# place/route provider를 tmap 으로 선택하면 필수.
TMAP_APP_KEY=

# Kakao Developers REST API 키. kakao_* provider 선택 시 필수.
# 주의: 카카오맵 Local API는 비즈 앱 전환(사업자)이 필요할 수 있음.
KAKAO_REST_API_KEY=
